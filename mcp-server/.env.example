# Required
PERF_SHARED_ROOT=\\vm-hostname\PerfTest

# Optional — Teams webhook notification
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/...

# Optional — Slack webhook notification
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Notification channel: terminal | teams | slack | both
NOTIFICATION_CHANNEL=terminal

# VM JMeter installation path (used by VM runner only)
JMETER_HOME=C:\apache-jmeter

# Allowed VM script path prefix (security: validated before job creation)
ALLOWED_VM_SCRIPT_PREFIX=C:\PerfTests

# Queue and runner folder names under PERF_SHARED_ROOT
JOB_QUEUE_DIR=__QUEUE__
JOB_RUNNING_DIR=__RUNNING__
JOB_COMPLETED_DIR=__COMPLETED__

# VM runner poll interval in seconds
RUNNER_POLL_INTERVAL_SECONDS=10

# VM runner idle shutdown timeout in minutes (waits for next job)
RUNNER_IDLE_TIMEOUT_MINUTES=60
